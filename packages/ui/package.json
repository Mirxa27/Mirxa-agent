{
    "name": "@mirxa-agent/ui",
    "version": "1.8.0",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "default": "./src/index.ts"
        }
    },
    "publishConfig": {
        "main": "./dist/lib/mirxa-agent-ui.js",
        "module": "./dist/lib/mirxa-agent-ui.js",
        "types": "./dist/lib/index.d.ts",
        "exports": {
            ".": {
                "types": "./dist/lib/index.d.ts",
                "import": "./dist/lib/mirxa-agent-ui.js",
                "default": "./dist/lib/mirxa-agent-ui.js"
            }
        }
    },
    "files": [
        "dist/"
    ],
    "description": "UI components for mirxa-agent - Panel and i18n",
    "keywords": [
        "mirxa-agent",
        "ui",
        "panel",
        "i18n"
    ],
    "author": "Mirxa27",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Mirxa27/Mirxa-agent.git",
        "directory": "packages/ui"
    },
    "homepage": "https://Mirxa27.github.io/Mirxa-agent/",
    "scripts": {
        "build": "vite build",
        "prepublishOnly": "node ../../scripts/pre-publish.js",
        "postpublish": "node ../../scripts/post-publish.js"
    }
}
